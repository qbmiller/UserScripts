        'zh-CN': {
            repoSize: '仓库大小：',
            repoDes: '仓库简介：',
            repoLang: '主要语言：',
            repoPage: '主页：',
            repoTotal: '统计：',
            repoLicense: '开源协议：',
            repoCreated: '创建时间：',
            repoUpdated: '最后更新：',
            repoPushed: '最后推送：',
            repoForks: '复刻：',
            repoStars: '星标：',
            repoWatcher: '关注者：',
            setToken: '设置 GitHub Token',
            tokenDesc: '输入您的 GitHub 个人访问令牌以提高 API 速率限制。',
            createToken: '创建新令牌',
            save: '保存',
            cancel: '取消',
            loading: '加载项目信息中...',
            error: '加载项目信息失败',
            networkError: '网络错误，请检查网络连接'
        }
    };

    const userLang = (navigator.languages && navigator.languages[0]) || navigator.language || 'en';
    const t = translations[userLang.startsWith('zh') ? 'zh-CN' : 'en'];

    // ==================== 样式注入 ====================
    GM_addStyle(`
        #github-project-info {
            padding: 15px;
            margin: 10px 0;
            background-color: #f6f8fa;
            border: 1px solid #e1e4e8;
            border-radius: 6px;
            animation: fadeIn 0.3s ease-in;
