        #github-project-info h3 {
            margin-top: 0;
            margin-bottom: 15px;
            font-size: 16px;
        }

        #github-project-info h3 a {
            text-decoration: none;
            color: #0969da;
        }

        #github-project-info h3 a:hover {
            text-decoration: underline;
        }

        #github-project-info .info-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 16px;
        }

        #github-project-info .info-column {
            padding: 0 8px;
        }

        #github-project-info .info-column:first-child {
            border-right: 1px solid #e1e4e8;
        }

        #github-project-info p {
            margin: 8px 0;
            font-size: 13px;
            line-height: 1.5;
        }

        #github-project-info strong {
            color: #24292f;
            font-weight: 600;
        }

        #github-project-info .stats {
            margin-left: 20px;
            line-height: 1.8;
        }

        #github-project-info .loading,
        #github-project-info .error {
            text-align: center;
            padding: 20px;
            font-size: 14px;
        }

        #github-project-info .error {
            color: #d73a49;
        }

        /* 暗黑模式支持 */
        @media (prefers-color-scheme: dark) {
            #github-project-info {
                background-color: #0d1117;
                border-color: #30363d;
                color: #c9d1d9;
            }

            #github-project-info h3 a {
                color: #58a6ff;
            }

            #github-project-info .info-column:first-child {
                border-right-color: #30363d;
            }

            #github-project-info strong {
                color: #c9d1d9;
            }
        }

        /* 响应式设计 */
        @media (max-width: 768px) {
            #github-project-info .info-grid {
                grid-template-columns: 1fr !important;
            }

            #github-project-info .info-column:first-child {
                border-right: none !important;
                border-bottom: 1px solid #e1e4e8;
                padding-bottom: 16px !important;
            }

            #github-project-info .info-column:last-child {
                padding-top: 16px !important;
            }
        }

        /* Token 设置模态框 */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            display: flex;
