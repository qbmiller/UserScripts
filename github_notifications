            repoPushed: 'Pushed:',
            repoForks: 'Forks:',
            repoStars: 'Stars:',
            repoWatcher: 'Watchers:',
            repoLicense: 'License:',
            repoPage: 'HomePage:',
            repoTotal: 'Statistics:',
